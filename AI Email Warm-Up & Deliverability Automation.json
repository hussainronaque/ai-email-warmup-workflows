      "parameters": {
        "jsCode": "try {\n  const aiResponse = JSON.parse($json.choices[0].message.content);\n\n  return [{\n    json: {\n      ...$('Loop Over Items').item.json,\n      subject: aiResponse.subject || \"No subject\",\n      body: aiResponse.body || \"No body\"\n    }\n  }];\n\n} catch (e) {\n\n  return [{\n    json: {\n      ...$('Loop Over Items').item.json,\n      subject: \"Hi there\",\n      body: $json.choices[0].message.content +\n        \"\\n\\nIf this isn't relevant, reply 'unsubscribe' and I won't contact you again.\"\n    }\n  }];\n\n}"
