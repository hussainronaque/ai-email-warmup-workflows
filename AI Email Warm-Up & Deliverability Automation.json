        "jsonBody": "{\n  \"model\": \"meta/llama-3.1-70b-instruct\",\n  \"max_tokens\": 200,\n  \"temperature\": 0.9,\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Write a very short casual friendly email between two small business owners in Morocco/North Africa who know each other. They are both exploring AI tools to save time and grow their business. Pick ONE random angle from these: saving time on admin tasks, automating customer replies, using AI for social media, reducing hiring costs with automation, AI for invoicing/accounting, chatbots for e-commerce, or scheduling automation. No sales language, sounds like a real person texting a friend. 2-3 sentences max. Every email must be completely unique - vary the angle, tone, and wording each time.\\n\\nCRITICAL: Your response must be ONLY valid JSON with no markdown, no backticks, no explanation. Output exactly:\\n{\\\"subject\\\":\\\"...\\\",\\\"body\\\":\\\"...\\\"}\\n\\nIMPORTANT: End the body with this exact line on a new line: \\\"If this isn't relevant, reply 'unsubscribe' and I won't contact you again.\\\"\"\n    }\n  ]\n}",
        "options": {}
