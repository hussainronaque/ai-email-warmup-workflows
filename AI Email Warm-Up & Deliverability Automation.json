        "jsCode": "const warmupAccounts = [\n  // Gmail (10)\n  \n];\n\nconst senders = [\n  { name: \"Zakaria\", email: \"test@test.com\" },\n  { name: \"Zakaria\", email: \"test@test.com\" }\n];\n\nconst items = [];\nfor (const acc of warmupAccounts) {\n  for (const sender of senders) {\n    items.push({\n      json: {\n        to: acc,\n        from: sender.email,\n        fromName: sender.name\n      }\n    });\n  }\n}\n\n// Shuffle for human-like random order\nfor (let i = items.length - 1; i > 0; i--) {\n  const j = Math.floor(Math.random() * (i + 1));\n  [items[i], items[j]] = [items[j], items[i]];\n}\n\nreturn items;"
      },
